#!/usr/bin/env bash
# Download and configure SmithGPT 1.0 (4GB) model.
# Usage: ./BuildGPT1.0
# The model uses ~4GB RAM. Requires llama-cpp-python.

set -euo pipefail
cd "$(dirname "$0")"

echo "=== SmithGPT 1.0 (4GB) ==="
echo "Target: $(pwd)/SmithAI-Server/models/smithgpt-1.0-4.gguf"
echo ""

# Install llama-cpp-python if not present
if ! python3 -c "import llama_cpp" 2>/dev/null; then
    echo "[1/3] Installing llama-cpp-python..."
    pip install llama-cpp-python --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu 2>/dev/null || \
    pip install llama-cpp-python 2>/dev/null || \
    CMAKE_ARGS="-DGGML_BLAS=ON -DGGML_BLAS_VENDOR=OpenBLAS" pip install llama-cpp-python
fi

# Ensure model directory
mkdir -p SmithAI-Server/models

# Download SmithGPT 1.0 model
echo "[2/3] Downloading SmithGPT 1.0 (4GB) — this may take a while..."
cd SmithAI-Server
python3 download_model.py \
  --url "https://huggingface.co/TheBloke/Mistral-7B-Instruct-v0.2-GGUF/resolve/main/mistral-7b-instruct-v0.2.Q4_K_M.gguf" \
  --name "smithgpt-1.0-4.gguf"

# Update config
echo "[3/3] Updating config.yml..."
cat > config.yml << 'CONF'
model:
  context_size: 4096
  max_tokens: 200
  n_threads: 2
  name: SmithGPT 1.0 4GB
  path: models/smithgpt-1.0-4.gguf
security:
  api_key: SMA-dQdZM9NrHjSr2KEJc8mOkgY4NOEzVBoS
server:
  host: 0.0.0.0
  port: 8000
CONF

echo ""
echo "✅ SmithGPT 1.0 ready!"
echo "Start the server: cd SmithAI-Server && python3 app.py"
echo "Or with Docker: docker-compose up -d"
